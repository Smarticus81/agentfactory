{
  "name": "@bevone/venue-agent",
  "version": "1.0.0",
  "private": true,
  "description": "BevOne per-venue voice agent runtime - converts AgentFactory into a POS voice assistant",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "agent:dev": "tsx src/agent/worker.ts dev",
    "agent:start": "node dist/agent/worker.js start",
    "lint": "eslint src/",
    "test": "vitest"
  },
  "dependencies": {
    "@livekit/agents": "^1.0.0",
    "@livekit/agents-plugin-openai": "^1.0.0",
    "@livekit/agents-plugin-deepgram": "^1.0.0",
    "@livekit/agents-plugin-silero": "^1.0.0",
    "livekit-server-sdk": "^2.0.0",
    "pg": "^8.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
    "@vercel/node": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "eslint": "^8.56.0",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": "22.x",
    "pnpm": ">=8.0.0"
  }
}
