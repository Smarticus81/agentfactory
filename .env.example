# BevOne Venue Agent - Environment Variables

# BevOne app config (injected by deployment engine)
# Contains venue-specific configuration: voice settings, tools, DB connection, POS config
APP_CONFIG='{"id":"test","name":"Test Bar","voice":{"name":"Bev","provider":"openai","voiceId":"alloy","personality":"You are a helpful bartender assistant.","greeting":"Ready! What can I get you?"},"tools":[],"connection":{"type":"POSTGRES","host":"localhost","port":5432,"database":"bevone","username":"bevone","password":"password","ssl":false},"pos":{"venueName":"Test Bar","taxRate":0.08,"currency":"USD","paymentMethods":["cash","credit","debit"],"tipPresets":[15,18,20]}}'

# LiveKit
LIVEKIT_URL="wss://bevone.livekit.cloud"
LIVEKIT_API_KEY="APIxxx"
LIVEKIT_API_SECRET="your-livekit-secret"

# Voice providers
OPENAI_API_KEY="sk-..."
DEEPGRAM_API_KEY="your-deepgram-key"

# Server
PORT=8080
